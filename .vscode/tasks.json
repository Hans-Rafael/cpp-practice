{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "Compilar C++20, g++ V.13.3.0",
            "command": "/usr/bin/g++",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "-std=c++20",
                "${file}",
