{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Ejecutar Programa (Linux)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${fileDirname}/build/${fileBasenameNoExtension}",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${fileDirname}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "Compilar C++20, g++ V.13.3.0",
            "miDebuggerPath": "/usr/bin/gdb"
        }
    ]
}
